---
import Layout from './Layout.astro';
const { frontmatter } = Astro.props;
const dateStr = new Date(frontmatter.pubDate).toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Layout title={frontmatter.title} description={frontmatter.description}>
  <div class="container" style="padding:2rem 1.5rem 4rem;">
    <div class="article-layout">
      <article>
        <div class="art-meta">
          {frontmatter.tags?.map(t => <span class="art-cat">{t}</span>)}
          <time>{dateStr}</time>
          <span class="art-author">— {frontmatter.author}</span>
        </div>
        <h1>{frontmatter.title}</h1>
        <p class="art-lead">{frontmatter.description}</p>
        <hr class="art-divider"/>
        <div class="art-body"><slot /></div>
      </article>
    </div>
  </div>
</Layout>
<style>
.article-layout { max-width: 780px; }
.art-meta { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; margin-bottom: 0.75rem; }
.art-cat { background: var(--red); color: #fff; font-family: 'Roboto Condensed', sans-serif; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.15rem 0.5rem; }
time, .art-author { font-family: 'Roboto Condensed', sans-serif; font-size: 0.85rem; color: var(--mid); }
h1 { font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 0.75rem; line-height: 1.15; }
.art-lead { font-size: 1.1rem; color: var(--mid); border-left: 4px solid var(--red); padding-left: 1rem; margin-bottom: 1.5rem; }
.art-divider { border: none; border-top: 3px double var(--black); margin-bottom: 1.5rem; }
.art-body :global(h2) { font-size: 1.4rem; margin: 2rem 0 0.75rem; border-bottom: 2px solid var(--black); padding-bottom: 0.25rem; }
.art-body :global(p) { margin-bottom: 1.2rem; line-height: 1.75; }
</style>
