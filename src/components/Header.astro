---
const today = new Date().toLocaleDateString('pl-PL', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
---
<header>
  <div class="top-bar">
    <span>{today}</span>
    <a href="https://ecoaudyt.app" target="_blank" rel="noopener">🔋 ecoaudyt.app</a>
  </div>
  <div class="masthead container">
    <a href="/" class="masthead-title">
      <span class="masth-main">OZE TRÓJMIASTO</span>
      <span class="masth-sub">Gdańsk · Gdynia · Sopot</span>
    </a>
    <nav class="main-nav">
      <a href="/">Strona główna</a>
      <a href="/blog">Artykuły</a>
      <a href="https://ecoaudyt.app" target="_blank" class="nav-break">⚡ Audyt energetyczny</a>
    </nav>
  </div>
  <div class="nav-strip container">
    <span class="breaking">🔴 AKTUALNOŚCI OZE</span>
  </div>
</header>

<style>
.top-bar { background: var(--black); color: #ccc; font-size: 0.75rem; font-family: 'Roboto Condensed', sans-serif; padding: 0.3rem 1.5rem; display: flex; justify-content: space-between; }
.top-bar a { color: #ccc; }
.masthead { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 1.5rem 1.5rem 1rem; border-bottom: 3px double var(--black); }
.masth-main { font-family: 'Roboto Condensed', sans-serif; font-size: clamp(2rem, 6vw, 3.5rem); font-weight: 700; color: var(--black); letter-spacing: -0.02em; display: block; }
.masth-sub { font-size: 0.8rem; color: var(--mid); letter-spacing: 0.2em; text-transform: uppercase; }
.masthead-title { text-decoration: none; }
.main-nav { display: flex; gap: 1.5rem; margin-top: 0.75rem; }
.main-nav a { font-family: 'Roboto Condensed', sans-serif; font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--black); }
.main-nav a:hover { color: var(--red); }
.nav-break { color: var(--red) !important; }
.nav-strip { background: var(--black); padding: 0.4rem 1.5rem; }
.breaking { color: var(--red-light); font-family: 'Roboto Condensed', sans-serif; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; }
</style>
