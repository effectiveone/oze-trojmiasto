---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Layout title="Artykuły — OZE Trójmiasto">
  <div class="container" style="padding:2rem 1.5rem 3rem;">
    <h1 style="font-size:2.5rem;border-bottom:3px double var(--black);padding-bottom:0.75rem;margin-bottom:1.5rem;">ARCHIWUM ARTYKUŁÓW</h1>
    <p style="color:var(--mid);font-family:'Roboto Condensed',sans-serif;margin-bottom:2rem;">{posts.length} artykułów w archiwum</p>
    {posts.length > 0 ? posts.map(p => <PostCard title={p.data.title} description={p.data.description} slug={p.slug} pubDate={p.data.pubDate} tags={p.data.tags} />) : <p style="color:var(--mid);padding:3rem 0;text-align:center;">Artykuły pojawią się wkrótce.</p>}
  </div>
</Layout>
