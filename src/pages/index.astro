---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Layout title="OZE Trójmiasto — Energia odnawialna w Gdańsku, Gdyni i Sopocie">
  <div class="container" style="padding:2rem 1.5rem;">
    {posts.length > 0 ? (
      <div class="newspaper-grid">
        <div class="lead-col">
          <article class="lead-story">
            <span class="lead-cat">{posts[0].data.tags?.[0] || 'Aktualności'}</span>
            <h1><a href={`/blog/${posts[0].slug}`}>{posts[0].data.title}</a></h1>
            <p>{posts[0].data.description}</p>
            <a href={`/blog/${posts[0].slug}`} class="lead-more">Czytaj całość →</a>
          </article>
          {posts.slice(3, 7).map(p => <PostCard title={p.data.title} description={p.data.description} slug={p.slug} pubDate={p.data.pubDate} tags={p.data.tags} />)}
        </div>
        <aside class="side-col">
          <h3 class="side-title">Inne artykuły</h3>
          {posts.slice(1, 3).map(p => <PostCard title={p.data.title} description={p.data.description} slug={p.slug} pubDate={p.data.pubDate} tags={p.data.tags} />)}
        </aside>
      </div>
    ) : (
      <div style="text-align:center;padding:4rem 0;color:var(--mid);">
        <h1 style="font-size:3rem;margin-bottom:1rem;">OZE TRÓJMIASTO</h1>
        <p>Portal o energii odnawialnej w Gdańsku, Gdyni i Sopocie.</p>
        <p>Pierwsze artykuły pojawią się wkrótce.</p>
      </div>
    )}
  </div>
</Layout>
<style>
.newspaper-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; }
.lead-story { border-bottom: 3px double var(--black); padding-bottom: 1.5rem; margin-bottom: 1.5rem; }
.lead-cat { background: var(--red); color: #fff; font-family: 'Roboto Condensed', sans-serif; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.2rem 0.6rem; display: inline-block; margin-bottom: 0.75rem; }
.lead-story h1 { font-size: clamp(1.5rem, 3vw, 2.5rem); margin-bottom: 0.75rem; line-height: 1.1; }
.lead-story h1 a { color: var(--black); }
.lead-story h1 a:hover { color: var(--red); }
.lead-story p { font-size: 1rem; color: var(--mid); margin-bottom: 1rem; }
.lead-more { font-family: 'Roboto Condensed', sans-serif; font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--red); }
.side-col { border-left: 1px solid var(--border); padding-left: 2rem; }
.side-title { font-family: 'Roboto Condensed', sans-serif; font-size: 0.75rem; letter-spacing: 0.12em; color: var(--red); text-transform: uppercase; border-bottom: 2px solid var(--red); padding-bottom: 0.3rem; margin-bottom: 1rem; }
@media (max-width: 700px) { .newspaper-grid { grid-template-columns: 1fr; } .side-col { border-left: none; border-top: 1px solid var(--border); padding: 1.5rem 0 0; } }
</style>
